# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# медиа, загруженные через админку (не коммитить бинарники)
/public/uploads/grenades/*
!/public/uploads/grenades/.gitkeep

# сырые захваты видео раскидок (тяжёлые, не идут в git)
content/lineups/_raw/**/*.mov
content/lineups/_raw/**/*.mkv
content/lineups/_raw/**/*.mp4
content/lineups/_raw/**/*.webm
# но текстовые планы и README — оставляем
!content/lineups/_raw/**/*.md
!content/lineups/_raw/**/.gitkeep

