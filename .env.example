# Секрет для POST /api/admin/lineups и GET (в production обязателен)
ADMIN_SECRET=your-secret-here

# В development без ADMIN_SECRET: в админке введи dev или оставь пустым (только локально)

# Postgres: контент админки (lineups, overrides, каталог, зоны) хранится в БД, а не в файлах на Vercel.
#
# --- Railway ---
# 1) В проекте Railway: New → Database → PostgreSQL.
# 2) Открой сервис Postgres → вкладка Variables: скопируй DATABASE_URL (для Vercel нужен публичный хост
#    из этой строки; у Railway он обычно уже в URL вместе с ?sslmode=require).
# 3) Таблица editor_content: либо SQL в Railway (если есть Run), либо с ПК из папки cs2-grenades:
#    npm run db:schema   (нужен публичный DATABASE_URL в .env)
# 4) В Vercel (Settings → Environment Variables) добавь DATABASE_URL с тем же значением.
# 5) Локальный seed из JSON: положи эту строку в .env и запусти npm run seed:editor-db
#
# Публичный TCP URL (Railway → Postgres → Connect). Нужен для Vercel и для npm run db:schema / seed с ПК.
# Если в DATABASE_URL только …railway.internal, задай DATABASE_PUBLIC_URL с публичным хостом.
# DATABASE_PUBLIC_URL=postgresql://user:pass@shuttle.proxy.rlwy.net:12345/railway
# DATABASE_URL=postgresql://user:pass@host.railway.app:5432/railway?sslmode=require
# На Vercel иногда приходит POSTGRES_URL — поддерживается тоже.

# Vercel: Storage → Blob → привязка к проекту — подставится BLOB_READ_WRITE_TOKEN.
# Локально: vercel env pull. Если задан — загрузки фото/видео идут в Blob (без лимита ~4.5 MB на функцию).
# BLOB_READ_WRITE_TOKEN=
