# Секрет для POST /api/admin/* (в production обязателен)
ADMIN_SECRET=your-secret-here

# В development без ADMIN_SECRET: в админке введи dev или оставь пустым (только локально)

# Контент редактора — Cloudflare D1 (см. wrangler.jsonc, binding DB).
# Локально: cp .dev.vars.example .dev.vars
#   npm run db:schema:local && npm run db:seed:local
# Прод: npm run db:schema && npm run db:seed
#
# Медиа (фото/видео раскидок):
#   - dev: public/uploads/grenades/
#   - prod: R2 bucket csutility-media (binding MEDIA в wrangler.jsonc)
#     wrangler r2 bucket create csutility-media
# После миграции с Vercel Blob: npm run db:fix-blob-urls
